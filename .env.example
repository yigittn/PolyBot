# Kopyala: cp .env.example .env  —  değerleri doldur; .env asla commit edilmez.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=2
CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137

POLYGON_RPC_URL=
POLYGON_RPC_BACKUP=
POLYGON_RPC_FALLBACK2=
ORACLE_POLL_INTERVAL_SECONDS=12

# Multi-Asset (virgülle ayır: BTC,ETH veya sadece BTC)
TRADING_ASSETS=BTC,ETH

DELTA_THRESHOLD_PERCENT=0.05
ORACLE_LAG_MIN_SECONDS=8
ORACLE_LAG_FRESH_SECONDS=3
EXCHANGE_DIVERGENCE_MAX=0.15

MAX_POSITION_USDC=1.00
DAILY_LOSS_LIMIT_USDC=5.0
MAX_TOKEN_PRICE=0.62
MIN_TOKEN_PRICE=0.28
ENTRY_WINDOW_START_SECONDS=45
ENTRY_WINDOW_END_SECONDS=8
COOLDOWN_AFTER_CONSECUTIVE_LOSSES=2
COOLDOWN_WINDOWS=4

# Kelly Criterion (quarter-Kelly default)
USE_KELLY=true
KELLY_FRACTION=0.25
KELLY_MAX_BET_PCT=0.20

EMERGENCY_BALANCE_MIN=2.0
EMERGENCY_CONSECUTIVE_LOSSES=5
EMERGENCY_ORDER_REJECTS=3
PROTECTION_TRADES=10
PROTECTION_DELAY_SECONDS=5

# Telegram (opsiyonel): TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID, TELEGRAM_ENABLED=true
# TELEGRAM_NOTIFY_MODE=all|results|critical
#   all      — baslangic, emir girisi, sonuc, uyari, kapanis, acil durdurma
#   results  — sadece pencere sonucu WIN/LOSS (+ acil durdurma)
#   critical — sadece acil durdurma
# TELEGRAM_NOTIFY_MODE=results

LOG_FILE=data/trades.jsonl
DRY_RUN=false
# DRY_RUN=true iken simüle bakiye (opsiyonel; yoksa 1000 USDC)
# DRY_RUN_BALANCE=1000
